# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/

# Environment files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example (template)
!.env.example

# Database files
*.db
*.db-journal
*.sqlite
*.sqlite3
server/prisma/dev.db
server/prisma/dev.db-journal
server/prisma/migrations/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Uploads (user-uploaded files, not source code)
server/uploads/covers/*
server/uploads/avatars/*
# Keep the folder structure
!server/uploads/covers/.gitkeep
!server/uploads/avatars/.gitkeep

# TypeScript build cache
*.tsbuildinfo

# Prisma generated client (regenerated on install)
server/node_modules/.prisma/

# Vite cache
client/.vite/
